
-# Supabase — safe to expose via VITE_ prefix (anon key only)
+# Supabase — anon key is safe for client exposure.
+# For Vite builds, VITE_SUPABASE_* is the default.
+# On Vercel, SUPABASE_* and NEXT_PUBLIC_SUPABASE_* are also accepted by this app.
 VITE_SUPABASE_URL=
 VITE_SUPABASE_ANON_KEY=
 
 # Gemini — server-side ONLY. Never add a VITE_ prefix here.
 # Used exclusively by /api/* Vercel serverless functions.
 GEMINI_API_KEY=
